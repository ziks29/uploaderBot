# Discord Bot Token (from Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID (from Developer Portal → General Information)
APPLICATION_ID=your_application_id_here

# AES-256 Encryption Key for storing API keys securely (32 bytes hex-encoded)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Optional: register slash commands only to a specific guild for instant updates (testing)
# Leave empty for global registration (up to 1 hour to propagate)
# DISCORD_GUILD_ID=your_guild_id_here

# Path to the user data file (default: keys.json in working directory)
# Override when running in Docker: /app/data/keys.json
# KEYS_FILE=keys.json
